---
import acornWordmark from './public/acorn-wordmark.png';
import favicon from './public/favicon.jpeg';
---
<html lang="en">
<head>
<meta charset="UTF-8" />
<link rel="icon" type="image/jpeg" href={favicon.src} />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Support - Acorn</title>
<meta name="description" content="Get help with Acorn. Chat with the team right here for quick questions." />
<meta name="robots" content="noindex" />
<script is:inline>
  document.documentElement.classList.add('is-loaded');
</script>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet" />

<style>
  :root {
    --rooted-green: #021F1C;
    --signal-sage: #A9C3B1;
    --muted: #B9C1BB;
    --line: rgba(190, 230, 200, 0.16);
    --glass: rgba(255, 255, 255, 0.045);
    --white: #F4F2EC;
    --font-serif: 'EB Garamond', Georgia, serif;
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    --font-mono: 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: var(--rooted-green);
    color: var(--white);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  .shell {
    margin: 0 auto;
    width: min(1120px, calc(100% - 48px));
  }

  h1 {
    color: var(--white);
    font-family: var(--font-serif);
    font-size: clamp(56px, 7vw, 82px);
    font-weight: 500;
    line-height: 0.96;
    margin-top: 18px;
  }

  .lead {
    color: rgba(255, 255, 255, 0.78);
    font-size: 19px;
    margin: 20px auto 44px;
  }

  .status-badge {
    background: var(--glass);
    border: 1px solid var(--line);
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.78);
    display: inline-flex;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.16em;
    padding: 8px 11px;
    text-transform: uppercase;
  }

  .topbar,
  .footer {
    background: var(--rooted-green);
  }

  .topbar {
    padding: 12px 0;
  }

  .nav-inner,
  .footer-inner {
    align-items: center;
    display: flex;
    gap: 24px;
    justify-content: space-between;
  }

  .nav-logo,
  .footer-logo {
    align-items: center;
    display: inline-flex;
    text-decoration: none;
    transition: transform 180ms ease;
  }

  .nav-logo:hover,
  .footer-logo:hover {
    transform: translateY(-2px);
  }

  .nav-logo img,
  .footer-logo img {
    display: block;
    height: 48px;
    object-fit: contain;
    width: auto;
  }

  .nav-back,
  .footer-links a {
    color: var(--muted);
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    transition: color 160ms ease, transform 160ms ease;
  }

  .nav-back:hover,
  .footer-links a:hover {
    color: var(--white);
    transform: translateY(-2px);
  }

  .hero {
    padding: 120px 0 140px;
  }

  .hero-inner {
    margin: 0 auto;
    max-width: 820px;
    text-align: center;
  }

  .chat-inline {
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 8px;
    margin: 32px auto 0;
    max-width: 100%;
    overflow: hidden;
  }

  .chat-inline iframe {
    border: 0;
    display: block;
    height: 600px;
    width: 100%;
  }

  .hours-note {
    color: rgba(255, 255, 255, 0.62);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    margin-top: 16px;
  }

  .footer {
    padding: 14px 0;
  }

  .footer-inner {
    flex-wrap: wrap;
  }

  .footer-meta {
    color: rgba(255, 255, 255, 0.62);
    font-size: 12px;
    font-weight: 600;
  }

  .footer-links {
    display: flex;
    gap: 18px;
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 650ms cubic-bezier(0.2, 0.8, 0.2, 1), transform 650ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    *,
    *::before,
    *::after {
      animation-duration: 0.001ms !important;
      animation-iteration-count: 1 !important;
      scroll-behavior: auto !important;
      transition-duration: 0.001ms !important;
    }

    [data-reveal] {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 900px) {
    .hero {
      padding: 84px 0 104px;
    }
  }

  @media (max-width: 640px) {
    .shell {
      width: min(100% - 32px, 1120px);
    }

    .nav-inner,
    .footer-inner {
      align-items: flex-start;
      flex-direction: column;
    }

    .nav-logo img,
    .footer-logo img {
      height: 40px;
    }

    .chat-inline iframe {
      height: 520px;
    }
  }
</style>
</head>
<body>

<nav class="topbar">
  <div class="shell nav-inner">
    <a href="/" class="nav-logo" aria-label="Acorn home">
      <img src={acornWordmark.src} alt="Acorn Rooted Intelligence" />
    </a>
    <a href="/" class="nav-back">Back to home</a>
  </div>
</nav>

<main>
  <section class="hero">
    <div class="shell hero-inner" data-reveal>
      <span class="status-badge">Support</span>
      <h1>We're here to help</h1>
      <p class="lead">Chat with the team right here for quick questions.</p>
      <p class="hours-note">We respond fast during business hours, Eastern.</p>

      <!-- tawk.to inline chat begin -->
      <div class="chat-inline">
        <iframe
          src="https://tawk.to/chat/6a5eece1642ea11d490f160b/1ju1cqksd"
          title="Chat with Acorn support"
          allow="microphone; camera"
        ></iframe>
      </div>
      <!-- tawk.to inline chat end -->
    </div>
  </section>
</main>

<footer class="footer">
  <div class="shell footer-inner">
    <a href="/" class="footer-logo" aria-label="Acorn home">
      <img src={acornWordmark.src} alt="Acorn Rooted Intelligence" />
    </a>
    <div class="footer-meta">&copy; 2026 Red Beard Consulting LLC. All rights reserved.</div>
    <div class="footer-links">
      <a href="/contact">Contact</a>
      <a href="/terms">Terms</a>
      <a href="/privacy">Privacy</a>
    </div>
  </div>
</footer>

<script is:inline>
  const revealItems = document.querySelectorAll('[data-reveal]');

  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.18 });

    revealItems.forEach((item) => observer.observe(item));
  } else {
    revealItems.forEach((item) => item.classList.add('is-visible'));
  }
</script>

</body>
</html>
